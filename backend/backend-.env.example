# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Port
PORT=5000

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/pixora

# Pexels API Key (Get free at https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# JWT Secret (Use a strong random string for production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_use_a_strong_random_string

# Optional: Environment (development or production)
NODE_ENV=development
