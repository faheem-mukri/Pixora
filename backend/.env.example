# Server Configuration
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/pixora

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# APIs
PEXELS_API_KEY=your_pexels_api_key_here

# Cloudinary (optional - for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# ============================================
# PRODUCTION (Vercel + Railway Deployment)
# ============================================

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pixora?retryWrites=true&w=majority
FRONTEND_URL=https://yourusername.vercel.app
NODE_ENV=production
