# Backend API URL (for development)
REACT_APP_API_URL=http://localhost:5000

# For production deployment on Vercel, set to your Railway backend URL:
# REACT_APP_API_URL=https://pixora-backend-xxxxx.railway.app

# Get the Railway URL from:
# 1. Deploy backend to Railway following VERCEL_DEPLOYMENT.md
# 2. Copy the deployment URL
# 3. Set it here for your .env.production file
